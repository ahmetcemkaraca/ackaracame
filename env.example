# Firebase Konfigürasyonu
REACT_APP_FIREBASE_API_KEY=your_api_key_here
REACT_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your_project_id
REACT_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id

# Firebase Functions - Günlük Blog Oluşturucu (firebase functions:config:set ile ayarlanır)
# NEWS_API_KEY - NewsAPI key (newsapi.org)
# OPENAI_API_KEY - OpenAI API key
# GITHUB_TOKEN - GitHub PAT (opsiyonel, gizli repo için)
# GITHUB_REPO - owner/repo (varsayılan: ahmetcemkaraca/ackaracame)
